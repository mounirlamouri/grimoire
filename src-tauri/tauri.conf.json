{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "grimoire",
  "version": "0.2.0",
  "identifier": "com.grimoire.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Grimoire",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdEQUExRDM5NUIyMTcyMDgKUldRSWNpRmJPUjJxZlRhU09HeTM4d1FIS3dZbTNJSElxd0FMaUtuTW9PYi91bFFNejY4cDN2bXUK",
      "endpoints": [
        "https://github.com/mounirlamouri/grimoire/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
        "deb",
        "rpm",
        "appimage",
        "nsis",
        "msi"
      ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
